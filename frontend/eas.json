{
  "cli": {
    "version": ">= 5.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": false,
        "scheme": "ZenRun"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "resourceClass": "m-medium",
        "scheme": "ZenRun"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "beta": {
      "distribution": "store",
      "channel": "beta",
      "ios": {
        "resourceClass": "m-medium",
        "scheme": "ZenRun"
      }
    },
    "production": {
      "distribution": "store",
      "env": {
        "LANG": "en_US.UTF-8",
        "LC_ALL": "en_US.UTF-8"
      },
      "ios": {
        "resourceClass": "m-medium",
        "scheme": "ZenRun"
      },
      "android": {
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "beta": {
      "ios": {
        "ascAppId": "6759347621"
      }
    },
    "production": {
      "ios": {
        "ascAppId": "6759347621"
      },
      "android": {
        "serviceAccountKeyPath": "./google-service-account.json",
        "track": "internal"
      }
    }
  }
}

