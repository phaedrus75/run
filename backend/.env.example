# Required — app will not start without this
SECRET_KEY=

# PostgreSQL connection string (Railway provides this)
DATABASE_URL=postgresql://user:password@host:port/dbname

# Resend API key for transactional emails
RESEND_API_KEY=

# Optional overrides
FROM_EMAIL=ZenRun <noreply@zenrun.co>
ALLOWED_ORIGINS=https://zenrun.co,https://www.zenrun.co

# One-time migration: email of user to assign orphaned data to
MIGRATION_USER_EMAIL=

# Coach (AI companion)
# Without ANTHROPIC_API_KEY set, the coach runs in stub mode (deterministic
# placeholder responses, no network calls). Set the key to enable live LLM
# calls. Override the default model with COACH_LLM_MODEL.
ANTHROPIC_API_KEY=
# COACH_LLM_MODE=stub|anthropic        # auto-detected from key if unset
# COACH_LLM_MODEL=claude-sonnet-4-5

# 🗺 Geocoding + walking-route stitching for Guide-suggested journeys.
# Without LOCATIONIQ_API_KEY set, the route planner falls back to the
# OpenStreetMap public services (Nominatim for geocoding, OSRM for
# routing). Those are fine for development but rate-limited (1 req/s)
# and not suitable for production traffic.
#
# LocationIQ is a hosted, OSM-backed alternative with a free tier of
# 5,000 requests/day at 2 req/s. Same response shape as Nominatim and
# OSRM, so this is a drop-in. Sign up at https://locationiq.com.
LOCATIONIQ_API_KEY=
# Region selector — "us1" (default) or "eu1". Use eu1 if most of your
# users are in Europe; latency is meaningfully lower. The free tier
# works on either.
# LOCATIONIQ_HOST=us1
